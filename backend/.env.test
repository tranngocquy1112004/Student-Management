# Test Environment Configuration
NODE_ENV=test
PORT=5001

# Test Database
MONGO_URI_TEST=mongodb://localhost:27017/school_management_test

# JWT Test Secrets
JWT_SECRET=test_jwt_secret_key_for_testing_only
JWT_REFRESH_SECRET=test_refresh_secret_key_for_testing_only
JWT_EXPIRE=15m
JWT_REFRESH_EXPIRE=7d

# Email Test Configuration (use mailhog or ethereal for testing)
EMAIL_HOST=localhost
EMAIL_PORT=1025
EMAIL_USER=test@test.com
EMAIL_PASS=test
EMAIL_FROM=Test System <test@test.com>

# Frontend Test URL
FRONTEND_URL=http://localhost:3001

# Redis Test Configuration (if using Redis)
REDIS_URL=redis://localhost:6379/1

# Test Settings
RATE_LIMIT_ENABLED=false
LOG_LEVEL=error
